#: src/libslic3r/PrintConfig.cpp:3071 src/libslic3r/PrintConfig.cpp:3082
#: src/libslic3r/PrintConfig.cpp:3092 src/libslic3r/PrintConfig.cpp:3347
#: src/libslic3r/PrintConfig.cpp:3355
msgid "mm/s²"
msgstr "мм/с²"

#: src/libslic3r/PrintConfig.cpp:771
msgid "Bridging angle"
msgstr "Угол (направление) мостов"

#: src/libslic3r/PrintConfig.cpp:773
msgid ""
"Bridging angle override. If left to zero, the bridging angle will be "
"calculated automatically. Otherwise the provided angle will be used for all "
"bridges. Use 180° for zero angle."
msgstr ""
"Принудительная печать мостов в одном, заданном направлении. Если задано 0, "
"угол печати мостов рассчитывается автоматически. В противном случае заданный "
"угол будет использоваться для всех мостов. Для нулевого угла установите 180°."

#: src/libslic3r/PrintConfig.cpp:776 src/libslic3r/PrintConfig.cpp:1126
#: src/libslic3r/PrintConfig.cpp:1926 src/libslic3r/PrintConfig.cpp:2710
#: src/libslic3r/PrintConfig.cpp:3756 src/libslic3r/PrintConfig.cpp:3935
#: src/libslic3r/PrintConfig.cpp:4007 src/libslic3r/PrintConfig.cpp:4017
