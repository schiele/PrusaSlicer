msgstr "Tiedostoa ei voi tallentaa"

#: src/slic3r/GUI/Plater.cpp:8095
msgid ""
"No export script configured. Set a script path in Print Settings > Output "
"options."
msgstr ""
"Vientiskriptiä ei ole määritetty. Aseta skriptin polku kohdassa "
"Tulostusasetukset > Tulostusvaihtoehdot."

#: src/slic3r/GUI/Plater.cpp:8102
#, boost-format
msgid "Export script not found: %1%"
msgstr "Vientiskriptiä ei löytynyt: %1%"

#: src/slic3r/GUI/Plater.cpp:8125
