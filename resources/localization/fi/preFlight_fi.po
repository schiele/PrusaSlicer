msgstr "Yksityisyyden suoja"

#: src/slic3r/GUI/Plater.cpp:7838
msgid ""
"The plater is empty.\n"
"Do you want to save the project?"
msgstr ""
"Alusta on tyhjä.\n"
"Haluatko tallentaa projektin?"

#: src/slic3r/GUI/Plater.cpp:7838
msgid "Save project"
msgstr "Tallenna projekti"

#: src/slic3r/GUI/Plater.cpp:7893
