#: src/libslic3r/Preset.cpp:2074 src/slic3r/GUI/ConfigWizard.cpp:1457
msgid "filament"
msgstr "tulostuslanka"

#: src/libslic3r/Preset.cpp:2076 src/slic3r/GUI/ConfigSnapshotDialog.cpp:80
msgid "SLA print"
msgstr "SLA tuloste"

#: src/libslic3r/Preset.cpp:2078 src/slic3r/GUI/ConfigSnapshotDialog.cpp:81
#: src/slic3r/GUI/ConfigWizard.cpp:1457 src/slic3r/GUI/GUI.cpp:233
msgid "SLA material"
msgstr "SLA materiaali"

#: src/libslic3r/Preset.cpp:2080 src/slic3r/GUI/ConfigSnapshotDialog.cpp:83
msgid "printer"
msgstr "tulostin"

#: src/libslic3r/Print.cpp:561
msgid "All objects are outside of the print volume."
msgstr "Kaikki kohteet ovat tulostustilavuuden ulkopuolella."

#: src/libslic3r/Print.cpp:564
msgid "The supplied settings will cause an empty print."
msgstr "Annetut asetukset johtavat tyhjään tulosteeseen."

#: src/libslic3r/Print.cpp:602
msgid ""
"Auto speed requires every filament to have a Max volumetric flow set. Check "
"your Filament Settings."
msgstr ""
"Automaattinopeus edellyttää, että jokaiselle filamentille on asetettu "
"maksimitilavuusvirtaus. Tarkista filamenttiasetuksesi."

#: src/libslic3r/Print.cpp:614
msgid "Ironing speed cannot be 0. Set an explicit speed or disable ironing."
msgstr ""
"Silityksen nopeus ei voi olla 0. Aseta nimenomainen nopeus tai poista "
"silitys käytöstä."

#: src/libslic3r/Print.cpp:621
msgid ""
"Avoid crossing perimeters option and avoid crossing curled overhangs option "
"cannot be both enabled together."
msgstr ""
"Vältä kehien ylitys-valinta ja vältä kiharien ulokkeiden ylitys-valinta "
"eivät voi molemmat olla valittuna yhdessä."

#: src/libslic3r/Print.cpp:631
msgid ""
"Only a single object may be printed at a time in Spiral Vase mode. Either "
"remove all but the last object, or enable sequential mode by "
"\"complete_objects\"."
msgstr ""
"Spiraalimaljatilassa voidaan tulostaa vain yksi kohde kerrallaan. Poista "
"kaikki paitsi viimeinen kohde tai ota peräkkäistila käyttöön "
"\"complete_objects\"-asetuksella."

#: src/libslic3r/Print.cpp:635
msgid ""
"The Spiral Vase option can only be used when printing single material "
"objects."
msgstr ""
"Spiraalimaljatilaa voi käyttää vain tulostettaessa yhden materiaalin "
"kohteita."

#: src/libslic3r/Print.cpp:639
msgid ""
"Machine limits cannot be emitted to G-Code when Klipper firmware flavor is "
"used. Change the value of machine_limits_usage."
msgstr ""
"Konerajoituksia ei voi kirjoittaa G-koodiin, kun Klipper-firmwaremuotoa "
"käytetään. Muuta machine_limits_usage-arvoa."

#: src/libslic3r/Print.cpp:676
#, boost-format
msgid ""
"While the object %1% itself fits the build volume, it exceeds the maximum "
"build volume height because of material shrinkage compensation."
msgstr ""
"Vaikka kohde %1% itse mahtuu tulostustilavuuteen, se ylittää "
"tulostustilavuuden enimmäiskorkeuden materiaalin kutistumiskompensoinnin "
"vuoksi."

#: src/libslic3r/Print.cpp:682
#, boost-format
msgid "The object %1% exceeds the maximum build volume height."
msgstr "Kohde %1% ylittää tulostustilavuuden enimmäiskorkeuden."

#: src/libslic3r/Print.cpp:690
#, boost-format
msgid ""
"While the object %1% itself fits the build volume, its last layer exceeds "
"the maximum build volume height."
msgstr ""
"Vaikka kohde %1% itse mahtuu tulostustilavuuteen, sen viimeinen kerros "
"ylittää tulostustilavuuden enimmäiskorkeuden."

#: src/libslic3r/Print.cpp:694
msgid ""
"You might want to reduce the size of your model or change current print "
"settings and retry."
msgstr ""
"Kannattaa ehkä pienentää mallia tai muuttaa nykyisiä tulostusasetuksia ja "
"yrittää uudelleen."

#: src/libslic3r/Print.cpp:712
msgid "Variable layer height is not supported with Organic supports."
msgstr "Muuttuvaa kerroskorkeutta ei tueta orgaanisten tukien kanssa."

#: src/libslic3r/Print.cpp:735
msgid ""
"The wipe tower is only supported if all extruders use filaments of the same "
"diameter."
msgstr ""
"Puhdistustornia tuetaan vain, jos kaikki extruderit käyttävät saman "
"halkaisijan filamenttia."

#: src/libslic3r/Print.cpp:744
msgid ""
"The Wipe Tower is currently only supported for the oozeBot Rapid, Marlin, "
"Klipper, RepRap/Sprinter, RepRapFirmware and Repetier G-code flavors."
msgstr ""
"Puhdistustornia tuetaan tällä hetkellä vain oozeBot Rapid-, Marlin-, "
"Klipper-, RepRap/Sprinter-, RepRapFirmware- ja Repetier-G-koodimuodoille."

#: src/libslic3r/Print.cpp:747
msgid ""
"The Wipe Tower is currently only supported with the relative extruder "
"addressing (use_relative_e_distances=1)."
msgstr ""
"Puhdistustornia tuetaan tällä hetkellä vain suhteellisen extruder-osoituksen "
"kanssa (use_relative_e_distances=1)."

#: src/libslic3r/Print.cpp:750
msgid ""
"Ooze prevention is only supported with the wipe tower when "
"'single_extruder_multi_material' is off."
msgstr ""
"Vuotoeston tuki puhdistustornin kanssa toimii vain, kun "
"'single_extruder_multi_material' on pois päältä."

#: src/libslic3r/Print.cpp:752
msgid ""
"The Wipe Tower currently does not support volumetric E (use_volumetric_e=0)."
msgstr ""
"Puhdistustorni ei tällä hetkellä tue tilavuuspohjaista E:tä "
"(use_volumetric_e=0)."

#: src/libslic3r/Print.cpp:754
msgid ""
"The Wipe Tower is currently not supported for multimaterial sequential "
"prints."
msgstr ""
"Puhdistustornia ei tällä hetkellä tueta monimateriaalisissa "
"peräkkäistulosteissa."

#: src/libslic3r/Print.cpp:768
msgid ""
"The Wipe Tower is only supported for multiple objects if they have equal "
"layer heights"
msgstr ""
"Puhdistustornia tuetaan useille kohteille vain, jos niillä on yhtä suuret "
"kerroskorkeudet"

#: src/libslic3r/Print.cpp:771
msgid ""
"The Wipe Tower is only supported for multiple objects if they are printed "
"over an equal number of raft layers"
msgstr ""
"Puhdistustornia tuetaan useille kohteille vain, jos ne tulostetaan yhtä "
"monella lautta-kerroksella"

#: src/libslic3r/Print.cpp:775
msgid ""
"The Wipe Tower is only supported for multiple objects if they are printed "
"with the same support_material_contact_distance"
msgstr ""
"Puhdistustornia tuetaan useille kohteille vain, jos ne tulostetaan samalla "
"support_material_contact_distance-arvolla"

#: src/libslic3r/Print.cpp:777
msgid ""
"The Wipe Tower is only supported for multiple objects if they are sliced "
"equally."
msgstr ""
"Puhdistustornia tuetaan useille kohteille vain, jos ne viipaloidaan samalla "
"tavalla."

#: src/libslic3r/Print.cpp:810
msgid ""
"The Wipe tower is only supported if all objects have the same variable layer "
"height"
msgstr ""
"Puhdistustornia tuetaan vain, jos kaikilla kohteilla on sama muuttuva "
"kerroskorkeus"

#: src/libslic3r/Print.cpp:835
msgid ""
"One or more object were assigned an extruder that the printer does not have."
msgstr ""
"Yhdelle tai useammalle kohteelle määritettiin extruder, jota tulostimessa ei "
"ole."

#: src/libslic3r/Print.cpp:853
#, boost-format
msgid "%1%=%2% mm is too low to be printable at a layer height %3% mm"
msgstr "%1%=%2% mm on liian alhainen tulostettavaksi kerroskorkeudella %3% mm"

#: src/libslic3r/Print.cpp:860
#, boost-format
msgid "Excessive %1%=%2% mm to be printable with a nozzle diameter %3% mm"
msgstr "Liian suuri %1%=%2% mm tulostettavaksi suuttimen halkaisijalla %3% mm"

#: src/libslic3r/Print.cpp:891 src/slic3r/GUI/ConfigManipulation.cpp:635
msgid ""
"The Wipe Tower currently supports the non-soluble supports only if they are "
"printed with the current extruder without triggering a tool change. (both "
"support_material_extruder and support_material_interface_extruder need to be "
"set to 0)."
msgstr ""
"Pyyhintätorni tukee tällä hetkellä liukenemattomia tukia vain, jos ne "
"tulostetaan nykyisellä ekstruuderilla ilman työkalun vaihtoa. (sekä "
"support_material_extruder että support_material_interface_extruder on "
"asetettava arvoon 0)."

#: src/libslic3r/Print.cpp:901
msgid ""
"Organic support tree tip diameter must not be smaller than support material "
"extrusion width."
msgstr ""
"Orgaanisen tukipuun kärjen halkaisija ei saa olla pienempi kuin "
"tukimateriaalin pursotusleveys."

#: src/libslic3r/Print.cpp:904
msgid ""
"Organic support branch diameter must not be smaller than 2x support material "
"extrusion width."
msgstr ""
"Orgaanisen tukipuun haaran halkaisija ei saa olla pienempi kuin 2x "
"tukimateriaalin pursotusleveys."

#: src/libslic3r/Print.cpp:907
msgid ""
"Organic support branch diameter must not be smaller than support tree tip "
"diameter."
msgstr ""
"Orgaanisen tukipuun haaran halkaisija ei saa olla pienempi kuin tukipuun "
"kärjen halkaisija."

#: src/libslic3r/Print.cpp:948
msgid "First layer height can't be greater than nozzle diameter"
msgstr ""
"Ensimmäisen kerroksen korkeus ei voi olla suurempi kuin suuttimen halkaisija"

#: src/libslic3r/Print.cpp:953
msgid "Layer height can't be greater than nozzle diameter"
msgstr "Kerroskorkeus ei voi olla suurempi kuin suuttimen halkaisija"

#: src/libslic3r/Print.cpp:981
msgid ""
"Relative extruder addressing requires resetting the extruder position at "
"each layer to prevent loss of floating point accuracy. Add \"G92 E0\" to "
"layer_gcode."
msgstr ""
"Suhteellinen extruder-osoitus edellyttää extruderin sijainnin nollausta "
"jokaisella kerroksella liukulukutarkkuuden menetyksen estämiseksi. Lisää "
"\"G92 E0\" layer_gcode-asetukseen."

#: src/libslic3r/Print.cpp:985
msgid ""
"\"G92 E0\" was found in before_layer_gcode, which is incompatible with "
"absolute extruder addressing."
msgstr ""
"\"G92 E0\" löytyi before_layer_gcode-asetuksesta, mikä on yhteensopimaton "
"absoluuttisen extruder-osoituksen kanssa."

#: src/libslic3r/Print.cpp:988
msgid ""
"\"G92 E0\" was found in layer_gcode, which is incompatible with absolute "
"extruder addressing."
msgstr ""
"\"G92 E0\" löytyi layer_gcode-asetuksesta, mikä on yhteensopimaton "
"absoluuttisen extruder-osoituksen kanssa."

