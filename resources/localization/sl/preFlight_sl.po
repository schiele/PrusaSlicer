msgstr ""
"Število plasti, potrebnih za prehod časa osvetlitve od začetnega časa "
"osvetlitve do časa osvetlitve"

#: src/libslic3r/PrintConfig.cpp:5779 src/libslic3r/PrintConfig.cpp:5780
msgid "Minimum exposure time"
msgstr "Najmanjši čas osvetlitve"

#: src/libslic3r/PrintConfig.cpp:5787 src/libslic3r/PrintConfig.cpp:5788
msgid "Maximum exposure time"
msgstr "Največji čas osvetlitve"

#: src/libslic3r/PrintConfig.cpp:5795 src/libslic3r/PrintConfig.cpp:5796
msgid "Exposure time"
msgstr "Čas osvetlitve"

#: src/libslic3r/PrintConfig.cpp:5802 src/libslic3r/PrintConfig.cpp:5803
msgid "Minimum initial exposure time"
msgstr "Najmanjši začetni čas osvetlitve"

#: src/libslic3r/PrintConfig.cpp:5810 src/libslic3r/PrintConfig.cpp:5811
msgid "Maximum initial exposure time"
msgstr "Največji začetni čas osvetlitve"

#: src/libslic3r/PrintConfig.cpp:5818 src/libslic3r/PrintConfig.cpp:5819
msgid "Initial exposure time"
msgstr "Začetni čas osvetlitve"

#: src/libslic3r/PrintConfig.cpp:5825 src/libslic3r/PrintConfig.cpp:5826
msgid "Correction for expansion"
msgstr "Korekcija za raztezanje"

#: src/libslic3r/PrintConfig.cpp:5832 src/libslic3r/PrintConfig.cpp:5833
