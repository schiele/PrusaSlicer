"Razporejanje je prezrlo naslednje objekte, ki se ne prilegajo eni podlagi:\n"
"%s"

#: src/slic3r/GUI/Plater.cpp:8946
msgid "Export"
msgstr "Izvozi"

#: src/slic3r/GUI/Plater.cpp:8947
msgid "Send to printer"
