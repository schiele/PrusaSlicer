#: src/slic3r/GUI/Tab.cpp:7457
msgid "LOCKED LOCK"
msgstr "ZAKLENJENA KLJUČAVNICA"

#. TRN Description for "LOCKED LOCK"
#: src/slic3r/GUI/Tab.cpp:7459
msgid ""
"indicates that the settings are the same as the system (or default) values "
"for the current option group"
msgstr ""
"označuje, da so nastavitve enake sistemskim (ali privzetim) vrednostim za "
"trenutno skupino možnosti"

#: src/slic3r/GUI/Tab.cpp:7462
msgid "UNLOCKED LOCK"
msgstr "ODKLENJENA KLJUČAVNICA"

#. TRN Description for "UNLOCKED LOCK"
#: src/slic3r/GUI/Tab.cpp:7464
msgid ""
"indicates that some settings were changed and are not equal to the system "
"(or default) values for the current option group.\n"
"Click the UNLOCKED LOCK icon to reset all settings for current option group "
"to the system (or default) values."
msgstr ""
"označuje, da so bile nekatere nastavitve spremenjene in niso enake "
"sistemskim (ali privzetim) vrednostim za trenutno skupino možnosti.\n"
"Kliknite ikono ODKLENJENE KLJUČAVNICE, da ponastavite vse nastavitve za "
"trenutno skupino možnosti na sistemske (ali privzete) vrednosti."

#: src/slic3r/GUI/Tab.cpp:7469
msgid "WHITE BULLET"
msgstr "BELA TOČKA"

#. TRN Description for "WHITE BULLET"
#: src/slic3r/GUI/Tab.cpp:7471
msgid ""
"for the left button: indicates a non-system (or non-default) preset,\n"
"for the right button: indicates that the settings hasn't been modified."
msgstr ""
"za levi gumb: označuje nesistemsko (ali neprivzeto) prednastavitev,\n"
"za desni gumb: označuje, da nastavitve niso bile spremenjene."

#: src/slic3r/GUI/Tab.cpp:7475
msgid "BACK ARROW"
msgstr "PUŠČICA NAZAJ"

#. TRN Description for "BACK ARROW"
#: src/slic3r/GUI/Tab.cpp:7477
msgid ""
"indicates that the settings were changed and are not equal to the last saved "
"preset for the current option group.\n"
"Click the BACK ARROW icon to reset all settings for the current option group "
"to the last saved preset."
msgstr ""
"označuje, da so bile nastavitve spremenjene in niso enake nazadnje shranjeni "
"prednastavitvi za trenutno skupino možnosti.\n"
"Kliknite ikono PUŠČICE NAZAJ, da ponastavite vse nastavitve za trenutno "
"skupino možnosti na nazadnje shranjeno prednastavitev."

#: src/slic3r/GUI/Tab.cpp:7483
msgid "EDIT VALUE"
msgstr "UREDI VREDNOST"

#. TRN Description for "EDIT VALUE" in the Help dialog (the icon is currently used only to edit custom gcodes).
#: src/slic3r/GUI/Tab.cpp:7485
msgid "clicking this icon opens a dialog allowing to edit this value."
msgstr "klik te ikone odpre pogovorno okno, ki omogoča urejanje te vrednosti."

#: src/slic3r/GUI/Tab.cpp:7493
msgid ""
"LOCKED LOCK icon indicates that the settings are the same as the system (or "
"default) values for the current option group"
msgstr ""
"Ikona ZAKLENJENE KLJUČAVNICE označuje, da so nastavitve enake sistemskim "
"(ali privzetim) vrednostim za trenutno skupino možnosti"

#: src/slic3r/GUI/Tab.cpp:7496
msgid ""
"UNLOCKED LOCK icon indicates that some settings were changed and are not "
"equal to the system (or default) values for the current option group.\n"
"Click to reset all settings for current option group to the system (or "
"default) values."
msgstr ""
"Ikona ODKLENJENE KLJUČAVNICE označuje, da so bile nekatere nastavitve "
"spremenjene in niso enake sistemskim (ali privzetim) vrednostim za trenutno "
"skupino možnosti.\n"
"Kliknite za ponastavitev vseh nastavitev za trenutno skupino možnosti na "
"sistemske (ali privzete) vrednosti."

#: src/slic3r/GUI/Tab.cpp:7499
msgid "WHITE BULLET icon indicates a non system (or non default) preset."
msgstr ""
"Ikona BELA TOČKA ponazarja ne sistemsko (ali ne privzeto) prednastavitev."

#: src/slic3r/GUI/Tab.cpp:7502
msgid ""
"WHITE BULLET icon indicates that the settings are the same as in the last "
"saved preset for the current option group."
msgstr ""
"Ikona BELA TOČKA ponazarja, da so nastavitve enake kot nazadnje shranjena "
"prednastavitev za trenutno skupino opcij."

#: src/slic3r/GUI/Tab.cpp:7504
msgid ""
"BACK ARROW icon indicates that the settings were changed and are not equal "
"to the last saved preset for the current option group.\n"
"Click to reset all settings for the current option group to the last saved "
"preset."
msgstr ""
"Ikona PUŠČICE NAZAJ označuje, da so bile nastavitve spremenjene in niso "
"enake nazadnje shranjeni prednastavitvi za trenutno skupino možnosti.\n"
"Kliknite za ponastavitev vseh nastavitev za trenutno skupino možnosti na "
"nazadnje shranjeno prednastavitev."

#: src/slic3r/GUI/Tab.cpp:7510
msgid ""
"LOCKED LOCK icon indicates that the value is the same as the system (or "
"default) value."
msgstr ""
"Ikona ZAKLENJENE KLJUČAVNICE označuje, da je vrednost enaka sistemski (ali "
"privzeti) vrednosti."

#: src/slic3r/GUI/Tab.cpp:7511
msgid ""
"UNLOCKED LOCK icon indicates that the value was changed and is not equal to "
"the system (or default) value.\n"
"Click to reset current value to the system (or default) value."
msgstr ""
"Ikona ODKLENJENE KLJUČAVNICE označuje, da je bila vrednost spremenjena in ni "
"enaka sistemski (ali privzeti) vrednosti.\n"
"Kliknite za ponastavitev trenutne vrednosti na sistemsko (ali privzeto) "
"vrednost."

#: src/slic3r/GUI/Tab.cpp:7517
msgid ""
"WHITE BULLET icon indicates that the value is the same as in the last saved "
"preset."
msgstr ""
"Ikona BELA TOČKA ponazarja, da so nastavitve enake kot nazadnje shranjena "
"prednastavitev."

#: src/slic3r/GUI/Tab.cpp:7519
msgid ""
"BACK ARROW icon indicates that the value was changed and is not equal to the "
"last saved preset.\n"
"Click to reset current value to the last saved preset."
msgstr ""
"Ikona PUŠČICE NAZAJ označuje, da je bila vrednost spremenjena in ni enaka "
"nazadnje shranjeni prednastavitvi.\n"
"Kliknite za ponastavitev trenutne vrednosti na nazadnje shranjeno "
"prednastavitev."

