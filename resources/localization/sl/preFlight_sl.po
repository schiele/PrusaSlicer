#: src/libslic3r/Format/3mf.cpp:2613
#, boost-format
msgid ""
"The selected 3mf file has been saved with a newer version of %1% and is not "
"compatible."
msgstr ""
"Izbrana datoteka 3mf je bila shranjena z novejšo različico %1% in ni "
"združljiva."

#: src/libslic3r/Format/3mf.cpp:2632
msgid ""
"The selected 3MF contains FDM supports painted object using a newer version "
"of preFlight and is not compatible."
msgstr ""
"Izbrana datoteka 3MF vsebuje objekt s pobarvanimi FDM podporami, ustvarjen z "
"novejšo različico preFlight, in ni združljiva."

#: src/libslic3r/Format/3mf.cpp:2640
msgid ""
"The selected 3MF contains seam painted object using a newer version of "
"preFlight and is not compatible."
msgstr ""
"Izbrana datoteka 3MF vsebuje objekt s pobarvanim šivom, ustvarjen z novejšo "
"različico preFlight, in ni združljiva."

#: src/libslic3r/Format/3mf.cpp:2648
msgid ""
"The selected 3MF contains multi-material painted object using a newer "
"version of preFlight and is not compatible."
msgstr ""
"Izbrana datoteka 3MF vsebuje večmaterialno pobarvan objekt, ustvarjen z "
"novejšo različico preFlight, in ni združljiva."

#: src/libslic3r/Format/AMF.cpp:1143
#, boost-format
