msgstr "Zakasnitev nagiba navzdol"

#: src/libslic3r/PrintConfig.cpp:6272
msgid "The delay between tilt-down cycles."
msgstr "Zakasnitev med cikli nagiba navzdol."

#: src/libslic3r/PrintConfig.cpp:6280
msgid "Tilt up offset steps"
msgstr "Koraki odmika nagiba navzgor"

#: src/libslic3r/PrintConfig.cpp:6281
msgid "Move tilt up to calibrated (horizontal) position minus this offset."
msgstr "Premakni nagib navzgor na umerjeni (vodoravni) položaj minus ta odmik."

#: src/libslic3r/PrintConfig.cpp:6289
msgid "Tilt up offset delay"
msgstr "Zakasnitev odmika nagiba navzgor"

#: src/libslic3r/PrintConfig.cpp:6290
msgid "Delay after the tilt reaches 'tilt_up_offset_steps' position."
msgstr "Zakasnitev po tem, ko nagib doseže položaj 'tilt_up_offset_steps'."

#: src/libslic3r/PrintConfig.cpp:6298
msgid "Tilt up cycles"
msgstr "Cikli nagiba navzgor"

#: src/libslic3r/PrintConfig.cpp:6299
msgid "Number of cycles to split the rest of the tilt-up."
msgstr "Število ciklov za razdelitev preostalega nagiba navzgor."

#: src/libslic3r/PrintConfig.cpp:6306
msgid "Tilt up delay"
msgstr "Zakasnitev nagiba navzgor"

#: src/libslic3r/PrintConfig.cpp:6307
msgid "The delay between tilt-up cycles."
msgstr "Zakasnitev med cikli nagiba navzgor."

#: src/libslic3r/PrintConfig.cpp:7279
msgid "Load config file"
msgstr "Naloži konfiguracijsko datoteko"

#: src/libslic3r/PrintConfig.cpp:7281
msgid ""
"Load configuration from the specified file. It can be used more than once to "
"load options from multiple files."
msgstr ""
"Naloži konfiguracijo iz navedene datoteke. Uporabiti jo je mogoče večkrat za "
"nalaganje možnosti iz več datotek."

#: src/libslic3r/PrintConfig.cpp:7307
