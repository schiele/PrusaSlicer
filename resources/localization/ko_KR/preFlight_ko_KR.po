msgid "Speed"
msgstr "속도"

#: src/libslic3r/PrintConfig.cpp:967
msgid "Speed for printing bridges."
msgstr "브릿지 인쇄 속도."

#: src/libslic3r/PrintConfig.cpp:968 src/libslic3r/PrintConfig.cpp:1615
#: src/libslic3r/PrintConfig.cpp:1625 src/libslic3r/PrintConfig.cpp:1635
#: src/libslic3r/PrintConfig.cpp:1643 src/libslic3r/PrintConfig.cpp:1651
