msgstr "チルトが「チルトアップのオフセット」位置に達した後の遅延。"

#: src/libslic3r/PrintConfig.cpp:6298
msgid "Tilt up cycles"
msgstr "チルトアップ サイクル"

#: src/libslic3r/PrintConfig.cpp:6299
msgid "Number of cycles to split the rest of the tilt-up."
msgstr "残りのチルトアップの動きを分割するサイクル数。"

#: src/libslic3r/PrintConfig.cpp:6306
msgid "Tilt up delay"
msgstr "チルトアップ 遅延"

#: src/libslic3r/PrintConfig.cpp:6307
