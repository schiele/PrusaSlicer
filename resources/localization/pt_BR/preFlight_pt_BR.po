#: src/libslic3r/PrintConfig.cpp:5602 src/libslic3r/PrintConfig.cpp:6096
#: src/slic3r/GUI/ArrangeSettingsDialogImgui.cpp:113
#: src/slic3r/GUI/Tab.cpp:7902
msgid "Fast"
msgstr "Rápido"

#: src/libslic3r/PrintConfig.cpp:5603
msgid "Fast tilt"
msgstr "Inclinação rápida"

#: src/libslic3r/PrintConfig.cpp:5604
msgid "Time of the fast tilt"
msgstr "Tempo da inclinação rápida"

#: src/libslic3r/PrintConfig.cpp:5611 src/libslic3r/PrintConfig.cpp:6096
#: src/slic3r/GUI/Tab.cpp:7903
msgid "Slow"
msgstr "Lento"

#: src/libslic3r/PrintConfig.cpp:5612
msgid "Slow tilt"
msgstr "Inclinação lenta"

#: src/libslic3r/PrintConfig.cpp:5613
msgid "Time of the slow tilt"
msgstr "Tempo da inclinação lenta"

#: src/libslic3r/PrintConfig.cpp:5620 src/libslic3r/PrintConfig.cpp:6096
#: src/slic3r/GUI/Tab.cpp:7904
msgid "High viscosity"
msgstr "Alta viscosidade"

#: src/libslic3r/PrintConfig.cpp:5621
msgid "Tilt for high viscosity resin"
msgstr "Inclinação para resina de alta viscosidade"

#: src/libslic3r/PrintConfig.cpp:5622
msgid "Time of the super slow tilt"
msgstr "Tempo da inclinação super lenta"

#: src/libslic3r/PrintConfig.cpp:5629
msgid "Area fill threshold"
msgstr "Limite de preenchimento de área"

#: src/libslic3r/PrintConfig.cpp:5631
msgid ""
"The value is expressed as a percentage of the bed area. If the area of a "
"particular layer is smaller than 'area_fill', then 'Below area fill "
"threshold' parameters are used to determine the layer separation (tearing) "
"procedure. Otherwise 'Above area fill threshold' parameters are used."
msgstr ""
"O valor é expresso como porcentagem da área da mesa. Se a área de uma camada "
"específica for menor que 'area_fill', os parâmetros 'Abaixo do limite de "
"preenchimento de área' são usados para determinar o procedimento de "
"separação de camadas (rasgamento). Caso contrário, os parâmetros 'Acima do "
"limite de preenchimento de área' são usados."

#: src/libslic3r/PrintConfig.cpp:5640 src/libslic3r/PrintConfig.cpp:5641
#: src/libslic3r/PrintConfig.cpp:5642
msgid "Printer scaling correction"
msgstr "Correção de dimensionamento da impressora"

#: src/libslic3r/PrintConfig.cpp:5648 src/libslic3r/PrintConfig.cpp:5650
msgid "Printer scaling correction in X axis"
msgstr "Correção de dimensionamento da impressora no eixo X"

#: src/libslic3r/PrintConfig.cpp:5649
msgid "Printer scaling X axis correction"
msgstr "Correção do eixo X da escala da impressora"

#: src/libslic3r/PrintConfig.cpp:5656 src/libslic3r/PrintConfig.cpp:5658
msgid "Printer scaling correction in Y axis"
msgstr "Correção de dimensionamento da impressora no eixo Y"

#: src/libslic3r/PrintConfig.cpp:5657
msgid "Printer scaling Y axis correction"
msgstr "Correção do eixo Y da escala da impressora"

#: src/libslic3r/PrintConfig.cpp:5664 src/libslic3r/PrintConfig.cpp:5666
msgid "Printer scaling correction in Z axis"
msgstr "Correção de dimensionamento da impressora no eixo Z"

#: src/libslic3r/PrintConfig.cpp:5665
msgid "Printer scaling Z axis correction"
msgstr "Correção do eixo Z de dimensionamento da impressora"

#: src/libslic3r/PrintConfig.cpp:5672 src/libslic3r/PrintConfig.cpp:5673
msgid "Printer absolute correction"
msgstr "Correção absoluta da impressora"

#: src/libslic3r/PrintConfig.cpp:5674
msgid ""
"Will inflate or deflate the sliced 2D polygons according to the sign of the "
"correction."
msgstr ""
"Irá inflar ou esvaziar os polígonos 2D cortados de acordo com o sinal da "
"correção."

#: src/libslic3r/PrintConfig.cpp:5681
msgid "Elephant foot minimum width"
msgstr "Largura mínima do pé de elefante"

#: src/libslic3r/PrintConfig.cpp:5683
msgid ""
"Minimum width of features to maintain when doing elephant foot compensation."
msgstr ""
"Largura mínima de características para manter ao fazer compensação do pé de "
"elefante."

#: src/libslic3r/PrintConfig.cpp:5690 src/slic3r/GUI/Sidebar.cpp:6839
msgid "Z compensation"
msgstr "Compensação Z"

#: src/libslic3r/PrintConfig.cpp:5692
msgid "Number of layers to Z correct to avoid cross layer bleed"
msgstr ""
"Número de camadas a corrigir em Z para evitar sangramento entre camadas"

#: src/libslic3r/PrintConfig.cpp:5698 src/libslic3r/PrintConfig.cpp:5699
msgid "Printer gamma correction"
msgstr "Correção de gama de impressora"

#: src/libslic3r/PrintConfig.cpp:5700
msgid ""
"This will apply a gamma correction to the rasterized 2D polygons. A gamma "
"value of zero means thresholding with the threshold in the middle. This "
"behaviour eliminates antialiasing without losing holes in polygons."
msgstr ""
"Isso aplicará uma correção de gama para os polígonos 2D rasterizados. Um "
"valor gama de zero significa limiarização com o limiar no meio. Este "
"comportamento elimina suavização sem perder buracos em polígonos."

#: src/libslic3r/PrintConfig.cpp:5718 src/libslic3r/PrintConfig.cpp:5719
msgid "SLA material type"
msgstr "Tipo de Material de SLA"

#: src/libslic3r/PrintConfig.cpp:5726 src/libslic3r/PrintConfig.cpp:5727
msgid "Initial layer height"
msgstr "Altura da camada inicial"

