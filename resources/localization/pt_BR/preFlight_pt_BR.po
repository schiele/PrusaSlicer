msgstr ""
"A lacuna entre a parte inferior do objeto e o pad gerado no modo de elevação "
"zero."

#: src/libslic3r/PrintConfig.cpp:6025
msgid "Pad object connector stride"
msgstr "Inserir pad entre o objeto"

