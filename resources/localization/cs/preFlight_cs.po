msgstr "Vizualizuje již naslicovaný a uložený G-code"

#: src/libslic3r/PrintConfig.cpp:7351
msgid "Save config file"
msgstr "Uložit konfigurační soubor"

#: src/libslic3r/PrintConfig.cpp:7352
msgid "Save configuration to the specified file."
msgstr "Uložit konfiguraci do zadaného souboru."

#: src/libslic3r/PrintConfig.cpp:7358
msgid "Output Model Info"
msgstr "Info o výstupním modelu"

#: src/libslic3r/PrintConfig.cpp:7359
msgid "Write information about the model to the console."
msgstr "Vypsat informace o modelu do konsole."

#: src/libslic3r/PrintConfig.cpp:7363
msgid "Export OBJ"
msgstr "Exportovat OBJ"

#: src/libslic3r/PrintConfig.cpp:7364
msgid "Export the model(s) as OBJ."
msgstr "Exportovat model(y) jako OBJ."

#: src/libslic3r/PrintConfig.cpp:7368
msgid "Export STL"
msgstr "Exportovat STL"

#: src/libslic3r/PrintConfig.cpp:7369
msgid "Export the model(s) as STL."
msgstr "Exportovat model(y) jako STL."

#: src/libslic3r/PrintConfig.cpp:7375
msgid "Export 3MF"
msgstr "Exportovat 3MF"

#: src/libslic3r/PrintConfig.cpp:7376
msgid "Export the model(s) as 3MF."
msgstr "Exportovat model(y) jako 3MF."

#: src/libslic3r/PrintConfig.cpp:7383
msgid "Slice"
msgstr "Slicovat"

#: src/libslic3r/PrintConfig.cpp:7385
msgid ""
"Slice the model as FFF or SLA based on the printer_technology configuration "
"value and export the result."
msgstr ""
"Slicovat model jako FFF nebo SLA na základě konfigurační hodnoty "
"printer_technology a exportovat výsledek."

#: src/libslic3r/PrintConfig.cpp:7391
msgid "Export SLA"
msgstr "Exportovat SLA"

#: src/libslic3r/PrintConfig.cpp:7392
msgid "Slice the model and export SLA printing layers as PNG."
msgstr "Naslicuje model a exportuje SLA tiskové vrstvy jako PNG soubory."

#: src/libslic3r/PrintConfig.cpp:7397 src/slic3r/GUI/KBShortcutsDialog.cpp:120
#: src/slic3r/GUI/ModernTabBar.cpp:962 src/slic3r/GUI/ModernTabBar.cpp:1115
#: src/slic3r/GUI/ModernTabBar.cpp:1149 src/slic3r/GUI/Plater.cpp:8946
msgid "Export G-code"
msgstr "Exportovat G-code"

#: src/libslic3r/PrintConfig.cpp:7398
msgid "Slice the model and export toolpaths as G-code."
msgstr "Naslicujte model a exportujte trasy jako G-code."

#: src/libslic3r/PrintConfig.cpp:7409
msgid "Align XY"
msgstr "Zarovnat XY"

#: src/libslic3r/PrintConfig.cpp:7410
msgid "Align the model to the given point."
msgstr "Zarovnejte model s daným bodem."

#: src/libslic3r/PrintConfig.cpp:7414 src/slic3r/GUI/Gizmos/GLGizmoCut.cpp:1440
#: src/slic3r/GUI/Widgets/TextInput.cpp:261
msgid "Cut"
msgstr "Řezat"

#: src/libslic3r/PrintConfig.cpp:7415
msgid "Cut model at the given Z."
msgstr "Rozříznout model v dané výšce Z."

#: src/libslic3r/PrintConfig.cpp:7419
#: src/slic3r/GUI/ArrangeSettingsDialogImgui.cpp:102
msgid "Center"
msgstr "Střed"

#: src/libslic3r/PrintConfig.cpp:7420
msgid "Center the print around the given center."
msgstr "Vycentrujte tisk kolem daného středu."

#: src/libslic3r/PrintConfig.cpp:7424
msgid "Don't arrange"
msgstr "Neuspořádávat"

#: src/libslic3r/PrintConfig.cpp:7425
msgid ""
"Do not rearrange the given models before merging and keep their original XY "
"coordinates."
msgstr ""
"Nepřeuspořádávejte modely před sloučením a tím ponecháním jejich původních "
"souřadnic v XY."

#: src/libslic3r/PrintConfig.cpp:7428
msgid "Ensure on bed"
msgstr "Zajistit položení na podložku"

#: src/libslic3r/PrintConfig.cpp:7430
msgid ""
"Lift the object above the bed when it is partially below. Enabled by "
"default, use --no-ensure-on-bed to disable."
msgstr ""
"Zvedne objekt nad podložku v případě, pokud je je částečně pod ním. Ve "
"výchozím nastavení povoleno, pro zakázání použijte --no-ensure-on-bed."

#: src/libslic3r/PrintConfig.cpp:7434
msgid "Duplicate"
msgstr "Duplikovat"

#: src/libslic3r/PrintConfig.cpp:7435
msgid "Multiply copies by this factor."
msgstr "Vynásobí kopie tímto číslem."

#: src/libslic3r/PrintConfig.cpp:7439
msgid "Duplicate by grid"
msgstr "Duplikovat mřížkou"

#: src/libslic3r/PrintConfig.cpp:7440
msgid "Multiply copies by creating a grid."
msgstr "Vynásobí kopie vytvořením mřížky."

#: src/libslic3r/PrintConfig.cpp:7443 src/slic3r/GUI/GUI_Factories.cpp:1143
#: src/slic3r/GUI/GUI_ObjectList.cpp:2538
msgid "Merge"
msgstr "Sloučit"

#: src/libslic3r/PrintConfig.cpp:7445
msgid ""
"Arrange the supplied models in a plate and merge them in a single model in "
"order to perform actions once."
msgstr ""
"Uspořádejte modely na tiskovou podložku a slučte je do jednoho modelu, "
"abyste s nimi mohli provádět akce jednou."

#: src/libslic3r/PrintConfig.cpp:7449
#: src/slic3r/GUI/Gizmos/GLGizmoAlign.cpp:2019
#: src/slic3r/GUI/Gizmos/GLGizmoRotate.cpp:630
#: src/slic3r/GUI/GUI_ObjectManipulation.cpp:806
#: src/slic3r/GUI/GUI_ObjectManipulation.cpp:852
msgid "Rotate"
msgstr "Otočit"

#: src/libslic3r/PrintConfig.cpp:7450
msgid "Rotation angle around the Z axis in degrees."
msgstr "Úhel otočení kolem osy Z ve stupních."

#: src/libslic3r/PrintConfig.cpp:7454
msgid "Rotate around X"
msgstr "Otočit okolo osy X"

#: src/libslic3r/PrintConfig.cpp:7455
msgid "Rotation angle around the X axis in degrees."
msgstr "Úhel otočení kolem osy X ve stupních."

#: src/libslic3r/PrintConfig.cpp:7459
msgid "Rotate around Y"
msgstr "Otočit okolo osy Y"

#: src/libslic3r/PrintConfig.cpp:7460
msgid "Rotation angle around the Y axis in degrees."
msgstr "Úhel otočení kolem osy Y ve stupních."

#: src/libslic3r/PrintConfig.cpp:7464
#: src/slic3r/GUI/Gizmos/GLGizmoMeasure.cpp:1571
#: src/slic3r/GUI/Gizmos/GLGizmoScale.cpp:129
#: src/slic3r/GUI/GUI_ObjectManipulation.cpp:300
#: src/slic3r/GUI/GUI_ObjectManipulation.cpp:807
#: src/slic3r/GUI/GUI_ObjectManipulation.cpp:822
#: src/slic3r/GUI/GUI_ObjectManipulation.cpp:841
#: src/slic3r/GUI/GUI_ObjectManipulation.cpp:853
#: src/slic3r/GUI/Sidebar.cpp:1802
msgid "Scale"
msgstr "Měřítko"

#: src/libslic3r/PrintConfig.cpp:7465
msgid "Scaling factor or percentage."
msgstr "Procentuální měřítko."

#: src/libslic3r/PrintConfig.cpp:7469 src/slic3r/GUI/GUI_Factories.cpp:1360
#: src/slic3r/GUI/GUI_Factories.cpp:1392
msgid "Split"
msgstr "Rozdělit"

#: src/libslic3r/PrintConfig.cpp:7470
msgid ""
"Detect unconnected parts in the given model(s) and split them into separate "
"objects."
msgstr ""
"Rozpoznat nepřipojené části daného modelu(ů) a rozdělit je do samostatných "
"objektů."

#: src/libslic3r/PrintConfig.cpp:7473
msgid "Scale to Fit"
msgstr "Vyplnit tiskový objem"

#: src/libslic3r/PrintConfig.cpp:7474
msgid "Scale to fit the given volume."
msgstr "Změnit velikost, aby se objekt vešel do zadaného tiskového prostoru."

#: src/libslic3r/PrintConfig.cpp:7483
msgid "Ignore non-existent config files"
msgstr "Ignorovat neexistující konfigurační soubory"

#: src/libslic3r/PrintConfig.cpp:7484
msgid "Do not fail if a file supplied to --load does not exist."
msgstr "Neselže, pokud neexistuje soubor... --load"

#: src/libslic3r/PrintConfig.cpp:7488
msgid ""
"Forward-compatibility rule when loading configurations from config files and "
"project files (3MF, AMF)."
msgstr ""
"Pravidlo dopředné kompatibility při načítání konfigurací z konfiguračních "
"souborů a souborů projektů (3MF, AMF)."

#: src/libslic3r/PrintConfig.cpp:7490
msgid ""
"This version of preFlight may not understand configurations produced by the "
"newest preFlight versions. For example, newer preFlight may extend the list "
"of supported firmware flavors. One may decide to bail out or to substitute "
"an unknown value with a default silently or verbosely."
msgstr ""
"Tato verze preFlightu nemusí být kompatibilní s konfiguracemi vytvořenými "
"nejnovějšími verzemi preFlightu. Novější verze preFlightu mohou například "
"rozšířit seznam podporovaných druhů firmwaru. Lze se rozhodnout, že to "
"budeme ignorovat, nebo že neznámou hodnotu nahradíme výchozí hodnotou."

#: src/libslic3r/PrintConfig.cpp:7495
msgid "Bail out on unknown configuration values"
msgstr "Záchrana při neznámých hodnotách konfigurace"

#: src/libslic3r/PrintConfig.cpp:7496
msgid ""
"Enable reading unknown configuration values by verbosely substituting them "
"with defaults."
msgstr ""
"Umožňuje načítání neznámých konfiguračních hodnot jejich výslovným "
"nahrazením výchozími hodnotami."

#: src/libslic3r/PrintConfig.cpp:7498
msgid ""
"Enable reading unknown configuration values by silently substituting them "
"with defaults."
msgstr ""
"Umožňuje načítání neznámých konfiguračních hodnot jejich tichým nahrazením "
"výchozími hodnotami."

#: src/libslic3r/PrintConfig.cpp:7503
msgid "Output File"
msgstr "Výstupní soubor"

#: src/libslic3r/PrintConfig.cpp:7505
msgid ""
"The file where the output will be written (if not specified, it will be "
"based on the input file)."
msgstr ""
"Soubor, do kterého bude zapisován výstup (pokud není zadán, bude vycházet ze "
"vstupního souboru)."

#: src/libslic3r/PrintConfig.cpp:7509
msgid "Data directory"
msgstr "Složka Data"

#: src/libslic3r/PrintConfig.cpp:7511
msgid ""
"Load and store settings at the given directory. This is useful for "
"maintaining different profiles or including configurations from a network "
"storage."
msgstr ""
"Načtěte a uložte nastavení z/do daného adresáře. To je užitečné pro "
"udržování různých profilů nebo  konfigurací ze síťového úložiště."

#: src/libslic3r/PrintConfig.cpp:7514
msgid "Maximum number of threads"
msgstr "Maximální počet vláken"

#: src/libslic3r/PrintConfig.cpp:7516
msgid ""
"Sets the maximum number of threads the slicing process will use. If not "
"defined, it will be decided automatically."
msgstr ""
"Nastavuje maximální počet vláken, která bude proces slicování používat. "
"Pokud není zadaná žádný hodnota, bude počet vláken určen automaticky."

#: src/libslic3r/PrintConfig.cpp:7520
msgid "Logging level"
msgstr "Úroveň logování"

#: src/libslic3r/PrintConfig.cpp:7521
msgid ""
"Sets logging sensitivity. 0:fatal, 1:error, 2:warning, 3:info, 4:debug, "
"5:trace\n"
"For example. loglevel=2 logs fatal, error and warning level messages."
msgstr ""
"Zvolte úroveň logování:  0:fatalní chyby, 1:chyby, 2:varování, 3:info, "
"4:ladění, 5:trasování\n"
"Například. loglevel=2 zaznamenává fatální chyby, chyby a varovné zprávy."

#: src/libslic3r/PrintConfig.cpp:7527
msgid "Automatic OpenGL antialiasing samples number selection"
msgstr "Automatická volba počtu vzorků antialiasingu OpenGL"

#: src/libslic3r/PrintConfig.cpp:7528
msgid ""
"Automatically select the highest number of samples for OpenGL antialiasing."
msgstr "Automaticky vybrat nejvyšší počet vzorků pro antialiasing OpenGL."

#: src/libslic3r/PrintConfig.cpp:7534
msgid "OpenGL version"
msgstr "Verze OpenGL"

#: src/libslic3r/PrintConfig.cpp:7535
msgid "Select a specific version of OpenGL"
msgstr "Vyberte konkrétní verzi OpenGL"

#: src/libslic3r/PrintConfig.cpp:7540
msgid "OpenGL compatibility profile"
msgstr "Profil kompatibility OpenGL"

#: src/libslic3r/PrintConfig.cpp:7541
msgid "Enable OpenGL compatibility profile"
msgstr "Povolení profilu kompatibility OpenGL"

#: src/libslic3r/PrintConfig.cpp:7546
msgid "OpenGL debug output"
msgstr "Debug výstup OpenGL"

#: src/libslic3r/PrintConfig.cpp:7547
msgid ""
"Activate OpenGL debug output on graphic cards which support it (OpenGL 4.3 "
"or higher)"
msgstr ""
"Aktivovat ladění OpenGL na grafických kartách, které jej podporují (OpenGL "
"4.3 nebo novější)."

#: src/libslic3r/PrintConfig.cpp:7553
msgid "Single instance mode"
msgstr "Režim jedné instance"

#: src/libslic3r/PrintConfig.cpp:7554
msgid ""
"If enabled, the command line arguments are sent to an existing instance of "
"GUI preFlight, or an existing preFlight window is activated. Overrides the "
"\"single_instance\" configuration value from application preferences."
msgstr ""
"Pokud je povoleno, argumenty příkazového řádku se odešlou do existující "
"instance grafického uživatelského rozhraní preFlight,u nebo se aktivuje "
"existující okno preFlight. Přepíše hodnotu konfigurace „single_instance“ z "
"nastavení aplikace."

#: src/libslic3r/PrintConfig.cpp:7559
msgid "Delete files after loading"
msgstr "Odstranění souborů po načtení"

#: src/libslic3r/PrintConfig.cpp:7560
msgid "Delete files after loading."
msgstr "Odstranění souborů po načtení."

#: src/libslic3r/PrintConfig.cpp:7564
msgid "Render with a software renderer"
msgstr "Vykreslování pomocí softwaru"

#: src/libslic3r/PrintConfig.cpp:7566
msgid ""
"Render with a software renderer. The bundled MESA software renderer is "
"loaded instead of the default OpenGL driver."
msgstr ""
"Vykreslení pomocí softwaru. Namísto výchozího ovladače OpenGL je načten "
"dodaný softwarový renderer MESA."

#: src/libslic3r/PrintConfig.cpp:7594
msgid "Current z-hop"
msgstr "Aktuální z-hop"

#: src/libslic3r/PrintConfig.cpp:7595
msgid "Contains z-hop present at the beginning of the custom G-code block."
msgstr "Obsahuje z-hop na začátku vlastního bloku G-code."

#: src/libslic3r/PrintConfig.cpp:7603
#: src/slic3r/GUI/GUI_ObjectManipulation.cpp:277
#: src/slic3r/GUI/GUI_ObjectManipulation.cpp:768
msgid "Position"
msgstr "Pozice"

#: src/libslic3r/PrintConfig.cpp:7605
msgid ""
"Position of the extruder at the beginning of the custom G-code block. If the "
"custom G-code travels somewhere else, it should write to this variable so "
"preFlight knows where it travels from when it gets control back."
msgstr ""
"Poloha extruderu na začátku vlastního bloku G-code. Pokud vlastní G-code "
"vytváří pohyb, měl by pohyb zapsat do této proměnné, aby preFlight věděl, "
"odkud se pohybuje, až získá zpět kontrolu."

#: src/libslic3r/PrintConfig.cpp:7609 src/slic3r/GUI/Sidebar.cpp:6963
msgid "Retraction"
msgstr "Retrakce"

#: src/libslic3r/PrintConfig.cpp:7611
msgid ""
"Retraction state at the beginning of the custom G-code block. If the custom "
"G-code moves the extruder axis, it should write to this variable so "
"preFlight deretracts correctly when it gets control back."
msgstr ""
"Stav retrakce na začátku vlastního G-code. Pokud vlastní G-code pohybuje "
"osou extruderu, měl by do této proměnné zapisovat, aby preFlight správně "
"zrušil deretrakce, když mu bude znovu předáno řízení."

#: src/libslic3r/PrintConfig.cpp:7615
msgid "Extra deretraction"
msgstr "Extra deretrakce"

#: src/libslic3r/PrintConfig.cpp:7616
msgid "Currently planned extra extruder priming after deretraction."
msgstr "Současně naplánované extra čištění extruderu po deretrakci."

#: src/libslic3r/PrintConfig.cpp:7619
msgid "Absolute E position"
msgstr "Absolutní poloha E"

#: src/libslic3r/PrintConfig.cpp:7620
msgid ""
"Current position of the extruder axis. Only used with absolute extruder "
"addressing."
msgstr ""
"Aktuální poloha osy extruderu. Používá se pouze při absolutním adresování "
"extruderu."

#: src/libslic3r/PrintConfig.cpp:7628
msgid "Current extruder"
msgstr "Aktuální extruder"

#: src/libslic3r/PrintConfig.cpp:7629
msgid "Zero-based index of currently used extruder."
msgstr "Index aktuálně používaného extrudéru (počítáno do nuly)."

#: src/libslic3r/PrintConfig.cpp:7632
msgid "Current object index"
msgstr "Aktuální index objektu"

#: src/libslic3r/PrintConfig.cpp:7633
msgid ""
"Specific for sequential printing. Zero-based index of currently printed "
"object."
msgstr ""
"Specifické pro sekvenční tisk. Index aktuálně tištěného objektu (počítáno do "
"nuly)."

#: src/libslic3r/PrintConfig.cpp:7636
msgid "Has single extruder MM priming"
msgstr "Má jeden extruder MM čištění"

#: src/libslic3r/PrintConfig.cpp:7637
msgid "Are the extra multi-material priming regions used in this print?"
msgstr "Jsou v tomto tisku použity dodatečné vícemateriálové čistící oblasti?"

#: src/libslic3r/PrintConfig.cpp:7640
msgid "Has wipe tower"
msgstr "Má čistící věž"

#: src/libslic3r/PrintConfig.cpp:7641
msgid "Whether or not wipe tower is being generated in the print."
msgstr "Zda se v tisku generuje čistící věž."

#: src/libslic3r/PrintConfig.cpp:7644
msgid "Initial extruder"
msgstr "Počáteční extruder"

#: src/libslic3r/PrintConfig.cpp:7645
msgid ""
"Zero-based index of the first extruder used in the print. Same as "
"initial_tool."
msgstr ""
"Index prvního extruderu použitého při tisku (počítáno do nuly). Stejně jako "
"initial_tool."

#. TRN: Meaning 'filament type of the initial filament'
#: src/libslic3r/PrintConfig.cpp:7649
msgid "Initial filament type"
msgstr "Typ počátečního filamentu"

#: src/libslic3r/PrintConfig.cpp:7650
msgid "String containing filament type of the first used extruder."
msgstr "Řetězec obsahující typ filamentu použitého v prvním extruderu."

#: src/libslic3r/PrintConfig.cpp:7653
msgid "Initial tool"
msgstr "Počáteční nástroj"

#: src/libslic3r/PrintConfig.cpp:7654
msgid ""
"Zero-based index of the first extruder used in the print. Same as "
"initial_extruder."
msgstr ""
"Index prvního extruderu použitého při tisku (počítáno do nuly). Stejně jako "
"initial_extruder."

#: src/libslic3r/PrintConfig.cpp:7657
msgid "Is extruder used?"
msgstr "Je extruder použitý?"

#: src/libslic3r/PrintConfig.cpp:7658
msgid ""
"Vector of booleans stating whether a given extruder is used in the print."
msgstr "Vektor booleanů udávající, zda je při tisku použit daný extruder."

#: src/libslic3r/PrintConfig.cpp:7666
msgid "Volume per extruder"
msgstr "Objem pro každý extruder"

#: src/libslic3r/PrintConfig.cpp:7667
msgid "Total filament volume extruded per extruder during the entire print."
msgstr ""
"Celkový objem filamentu vytlačeného daným extruderem během celého tisku."

#: src/libslic3r/PrintConfig.cpp:7670 src/libslic3r/PrintConfig.cpp:7678
msgid "Print time (normal mode)"
msgstr "Doba tisku (normální režim)"

#: src/libslic3r/PrintConfig.cpp:7671
msgid ""
"Estimated print time when printed in normal mode (i.e. not in silent mode). "
"Same as print_time."
msgstr ""
"Odhadovaná doba tisku při tisku v normálním režimu (tj. ne v tichém režimu). "
"Stejné jako print_time."

#: src/libslic3r/PrintConfig.cpp:7674
msgid "Number of printing extruders"
msgstr "Počet tisknoucích extruderů"

#: src/libslic3r/PrintConfig.cpp:7675
msgid "Number of extruders used during the print."
msgstr "Počet extruderů použitých při tisku."

#: src/libslic3r/PrintConfig.cpp:7680
msgid ""
"Estimated print time when printed in normal mode (i.e. not in silent mode). "
"Same as normal_print_time."
msgstr ""
"Odhadovaná doba tisku při tisku v normálním režimu (tj. ne v tichém režimu). "
"Stejné jako normal_print_time."

#: src/libslic3r/PrintConfig.cpp:7683
msgid "Used filament types"
msgstr "Použité typy filamentů"

#: src/libslic3r/PrintConfig.cpp:7684
msgid "Comma-separated list of all filament types used during the print."
msgstr "Seznam všech typů filamentů použitých při tisku oddělený čárkou."

#: src/libslic3r/PrintConfig.cpp:7687
msgid "Print time (silent mode)"
msgstr "Doba tisku (tichý režim)"

#: src/libslic3r/PrintConfig.cpp:7688
msgid "Estimated print time when printed in silent mode."
msgstr "Odhadovaná doba tisku při tisku v tichém režimu."

#: src/libslic3r/PrintConfig.cpp:7691
msgid "Total cost"
msgstr "Celkové náklady"

#: src/libslic3r/PrintConfig.cpp:7692
msgid ""
"Total cost of all material used in the print. Calculated from cost in "
"Filament Settings."
msgstr ""
"Celkové náklady na veškerý materiál použitý při tisku. Vypočítá se z nákladů "
"v nastavení filamentu."

#: src/libslic3r/PrintConfig.cpp:7695 src/libslic3r/PrintConfig.cpp:7724
msgid "Total weight"
msgstr "Celková hmotnost"

#: src/libslic3r/PrintConfig.cpp:7696 src/libslic3r/PrintConfig.cpp:7725
msgid ""
"Total weight of the print. Calculated from density in Filament Settings."
msgstr "Celková hmotnost tisku. Vypočítá se z hustoty v nastavení filamentu."

#: src/libslic3r/PrintConfig.cpp:7699
msgid "Total wipe tower cost"
msgstr "Celkové náklady na čistící věž"

#: src/libslic3r/PrintConfig.cpp:7700
msgid ""
"Total cost of the material wasted on the wipe tower. Calculated from cost in "
"Filament Settings."
msgstr ""
"Celkové náklady na materiál spotřebovaný v čistící věži. Vypočítáno z "
"nákladů v nastavení filamentu."

#: src/libslic3r/PrintConfig.cpp:7703
msgid "Wipe tower volume"
msgstr "Objem čistící věže"

#: src/libslic3r/PrintConfig.cpp:7704
