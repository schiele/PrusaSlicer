#: src/libslic3r/PrintConfig.cpp:441
msgid ""
"Picture sizes to be stored into a .gcode / .bgcode and .sl1 / .sl1s files, "
"in the following format: \"XxY/EXT, XxY/EXT, ...\"\n"
"Currently supported extensions are PNG, QOI, JPG, BTT_TFT and COLPIC."
msgstr ""
"Tamaños de imagen que se almacenarán en archivos .gcode / .bgcode "
"y .sl1 / .sl1s, en el siguiente formato: \"XxY/EXT, XxY/EXT, ...\"\n"
"Las extensiones admitidas actualmente son PNG, QOI, JPG, BTT_TFT y COLPIC."

#: src/libslic3r/PrintConfig.cpp:448
msgid "Format of G-code thumbnails"
msgstr "Formato de miniaturas de código G"

#: src/libslic3r/PrintConfig.cpp:450
msgid ""
"Format of G-code thumbnails: PNG for best quality, JPG for smallest size, "
"QOI for low memory firmware, BTT_TFT for BigTreeTech touchscreens, COLPIC "
"for Elegoo Neptune-series on-screen previews"
msgstr ""
"Formato de las miniaturas de G-code: PNG para mejor calidad, JPG para menor "
"tamaño, QOI para firmware de poca memoria, BTT_TFT para pantallas táctiles "
"BigTreeTech, COLPIC para las vistas previas en pantalla de la serie Elegoo "
"Neptune"

