#: src/libslic3r/PrintConfig.cpp:441
msgid ""
"Picture sizes to be stored into a .gcode / .bgcode and .sl1 / .sl1s files, "
"in the following format: \"XxY/EXT, XxY/EXT, ...\"\n"
"Currently supported extensions are PNG, QOI, JPG, BTT_TFT and COLPIC."
msgstr ""
"Mides de les imatges que s'emmagatzemaran en fitxers .gcode / .bgcode "
"i .sl1 / .sl1s, en el format següent: \"XxY/EXT, XxY/EXT, ...\"\n"
"Les extensions admeses actualment són PNG, QOI, JPG, BTT_TFT i COLPIC."

#: src/libslic3r/PrintConfig.cpp:448
msgid "Format of G-code thumbnails"
msgstr "Format de les miniatures del codi G"

#: src/libslic3r/PrintConfig.cpp:450
msgid ""
"Format of G-code thumbnails: PNG for best quality, JPG for smallest size, "
"QOI for low memory firmware, BTT_TFT for BigTreeTech touchscreens, COLPIC "
"for Elegoo Neptune-series on-screen previews"
msgstr ""
"Format de les miniatures del G-code: PNG per a la millor qualitat, JPG per a "
"la mida més petita, QOI per a firmware amb poca memòria, BTT_TFT per a "
"pantalles tàctils BigTreeTech, COLPIC per a les previsualitzacions en "
"pantalla de la sèrie Elegoo Neptune"

