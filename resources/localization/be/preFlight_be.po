msgstr "Загрузіць файл наладкі"

#: src/libslic3r/PrintConfig.cpp:7281
msgid ""
"Load configuration from the specified file. It can be used more than once to "
"load options from multiple files."
msgstr ""
"Загрузіць наладкі з паказанага файлу.\n"
"Можна ўжываць некалькі разоў для загрузкі наладаў з некалькіх файлаў."

#: src/libslic3r/PrintConfig.cpp:7307
msgid "Help"
msgstr "Дапамога"

#: src/libslic3r/PrintConfig.cpp:7308
msgid "Show this help."
msgstr "Адлюстраваць дапамогу."

#: src/libslic3r/PrintConfig.cpp:7313
msgid "Help (FFF options)"
msgstr "Дапамога (налады FFF)"

#: src/libslic3r/PrintConfig.cpp:7314
msgid "Show the full list of print/G-code configuration options."
msgstr "Адлюстраваць поўны спіс наладаў друку/G-code."

#: src/libslic3r/PrintConfig.cpp:7318
msgid "Help (SLA options)"
msgstr "Дапамога (налады SLA)"

#: src/libslic3r/PrintConfig.cpp:7319
msgid "Show the full list of SLA print configuration options."
msgstr "Адлюстраваць поўны спіс наладаў друку SLA."

#: src/libslic3r/PrintConfig.cpp:7343
msgid "G-code viewer"
msgstr "Прагляд G-code"

#: src/libslic3r/PrintConfig.cpp:7344
msgid "Visualize an already sliced and saved G-code"
msgstr "Візуалізацыя ўжо нарэзанага і захаванага G-code"

#: src/libslic3r/PrintConfig.cpp:7351
msgid "Save config file"
msgstr "Захаваць наладкі ў файл"

#: src/libslic3r/PrintConfig.cpp:7352
msgid "Save configuration to the specified file."
msgstr "Захаваць наладкі ў паказаны файл."

#: src/libslic3r/PrintConfig.cpp:7358
msgid "Output Model Info"
msgstr "Інфармацыя аб выходнай мадэлі"

#: src/libslic3r/PrintConfig.cpp:7359
msgid "Write information about the model to the console."
msgstr "Запісать інфармацыю аб мадэлі ў кансоль."

#: src/libslic3r/PrintConfig.cpp:7363
msgid "Export OBJ"
msgstr "Экспартаваць у OBJ"

#: src/libslic3r/PrintConfig.cpp:7364
msgid "Export the model(s) as OBJ."
msgstr "Экспартаваць мадэль ў фармат OBJ."

#: src/libslic3r/PrintConfig.cpp:7368
msgid "Export STL"
msgstr "Экспартаваць у STL"

#: src/libslic3r/PrintConfig.cpp:7369
msgid "Export the model(s) as STL."
msgstr "Экспартаваць мадэлі ў фармат STL."

#: src/libslic3r/PrintConfig.cpp:7375
msgid "Export 3MF"
msgstr "Экспартаваць у 3MF"

#: src/libslic3r/PrintConfig.cpp:7376
msgid "Export the model(s) as 3MF."
msgstr "Экспартаваць мадэлі ў фармат 3MF."

#: src/libslic3r/PrintConfig.cpp:7383
msgid "Slice"
msgstr "Нарэзаць"

#: src/libslic3r/PrintConfig.cpp:7385
msgid ""
"Slice the model as FFF or SLA based on the printer_technology configuration "
"value and export the result."
msgstr ""
"Нарэзаць мадэль як FFF ці SLA на падставе значэння канфігурацыі "
"printer_technology і экспартаваць вынік."

#: src/libslic3r/PrintConfig.cpp:7391
msgid "Export SLA"
msgstr "Экспартаваць у SLA"

#: src/libslic3r/PrintConfig.cpp:7392
msgid "Slice the model and export SLA printing layers as PNG."
msgstr "Нарэзаць мадэль і экспартаваць пласты друку для SLA у фармаце PNG."

#: src/libslic3r/PrintConfig.cpp:7397 src/slic3r/GUI/KBShortcutsDialog.cpp:120
#: src/slic3r/GUI/ModernTabBar.cpp:962 src/slic3r/GUI/ModernTabBar.cpp:1115
