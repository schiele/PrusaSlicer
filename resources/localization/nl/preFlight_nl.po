msgstr "Gebruik basisplaat"

#: src/libslic3r/PrintConfig.cpp:5926 src/libslic3r/PrintConfig.cpp:5933
#: src/libslic3r/PrintConfig.cpp:5947 src/libslic3r/PrintConfig.cpp:5958
#: src/libslic3r/PrintConfig.cpp:5968 src/libslic3r/PrintConfig.cpp:5990
#: src/libslic3r/PrintConfig.cpp:6001 src/libslic3r/PrintConfig.cpp:6008
